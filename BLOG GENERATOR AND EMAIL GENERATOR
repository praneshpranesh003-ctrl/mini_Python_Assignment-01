import google.generativeai as genai
from google.colab import userdata

# Configure API
genai.configure(api_key=userdata.get('GEMINI_API_KEYS1'))

model = genai.GenerativeModel(
    model_name='gemini-2.5-flash-lite',
    system_instruction="You are a helpful content generator."
)

# Start chat
chat = model.start_chat(history=[])

print("===== AI CONTENT GENERATOR =====")

while True:

    print("\n1. Blog Generator")
    print("2. Email Generator")
    print("3. Exit")

    choice = input("Enter your choice: ")

    if choice == "1":

        topic = input("Enter Topic: ")
        tone = input("Enter Tone: ")
        word_count = input("Enter Word Count: ")

        prompt = f"""
        You are an experienced blog writer.

        Write a blog on the topic: {topic}

        Tone: {tone}
        Word Count: {word_count}

        Include:
        - Attractive Title
        - Introduction
        - 2-3 Body Sections
        - Conclusion
        """

        response = chat.send_message(
            prompt,
            generation_config={"temperature": 0.7}
        )

        print("\n===== GENERATED BLOG =====\n")
        print(response.text)

        
        print("\nBlog saved as blog_output.txt")

    elif choice == "2":

        recipient = input("Recipient: ")
        purpose = input("Purpose: ")
        tone = input("Enter Tone: ")

        prompt = f"""
        You are a professional email writer.

        Write an email.

        Recipient: {recipient}
        Purpose: {purpose}
        Tone: {tone}

        Include:
        - Subject Line
        - Professional Greeting
        - Email Body
        - Professional Closing
        """

        response = chat.send_message(
            prompt,
            generation_config={"temperature": 0.3}
        )

        print("\n===== GENERATED EMAIL =====\n")
        print(response.text)

        

        print("\nEmail saved as email_output.txt")

    elif choice == "3":
        print("Goodbye!")
        break

    else:
        print("Invalid choice. Please try again.")
