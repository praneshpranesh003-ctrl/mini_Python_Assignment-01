import google.generativeai as genai
from google.colab import userdata

# Configure API
genai.configure(api_key=userdata.get("GEMINI_API_KEYS"))


# KNOWLEDGE BASE

knowledge_base = """
Company: Spartanes D Luffy Fitness Center

=== Membership & Services ===

Q: What are your working hours?
A: We are open Monday to Saturday from 5:00 AM to 10:00 PM and Sunday from 6:00 AM to 8:00 PM.

