A: Call us at 9876543210 or email support@spartanesdluffyfitness.com.

Contact Number: 9876543210
Email: support@spartanesdluffyfitness.com
"""

# ===========================
# SYSTEM INSTRUCTION
# ===========================

system_instruction = f"""
You are the customer support assistant for Spartanes D Luffy Fitness Center.

Follow these rules strictly:

1. Answer ONLY using the knowledge base below.
2. If the answer is not available in the knowledge base, reply exactly:
"I'm sorry, I don't have information about that. Please contact our support team at 9876543210 or email support@spartanesdluffyfitness.com."
3. Be polite and professional.

========== KNOWLEDGE BASE ==========

{knowledge_base}
"""


# MODEL

model = genai.GenerativeModel(
    model_name="gemini-2.5-flash-lite",
    system_instruction=system_instruction
)

# Start chat session
chat = model.start_chat(history=[])

print("===== Spartanes D Luffy Fitness Center FAQ Chatbot =====")
print("Type 'quit' to exit.\n")

# CHAT LOOP
while True:

    user_input = input("You: ")

    if user_input.lower() in ["quit", "exit", "bye"]:
        print("Bot: Goodbye! Have a great day.")
        break

    response = chat.send_message(
        user_input,
        generation_config={
            "temperature": 0.2
        }
    )

    print(f"Bot: {response.text}\n")
