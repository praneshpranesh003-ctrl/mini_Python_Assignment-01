import google.generativeai as genai
from google.colab import userdata

# Configure API
genai.configure(api_key=userdata.get("GEMINI_API_KEYS"))

# Create Model
model = genai.GenerativeModel(
    model_name="gemini-2.5-flash-lite",
    system_instruction="""
    You are an experienced blog writer.

    Rules:
    - Write engaging blogs.
    - Include an attractive title.
    - Write an introduction.
    - Write 2-3 body sections.
    - End with a conclusion.
    - Follow the user's requested tone and word count.
    """
)

# Start Chat
chat = model.start_chat(history=[])

print("===== BLOG GENERATOR =====")
print("Type 'quit' to exit.\n")

while True:

    topic = input("Enter Topic: ")

    if topic.lower() in ["quit", "exit", "bye"]:
        print("Goodbye!")
        break

    tone = input("Enter Tone (formal/casual/Gen Z/professional): ")
    word_count = input("Enter Word Count: ")

    prompt = f"""
    Write a blog on the topic: {topic}

    Tone: {tone}

    Word Count: {word_count}
    """

    response = chat.send_message(
        prompt,
        generation_config={"temperature": 0.7}
    )

    print("\n===== GENERATED BLOG =====\n")
    print(response.text)

    with open("blog_output.txt", "w") as file:
        file.write(response.text)

    print("\nBlog saved as blog_output.txt\n")
